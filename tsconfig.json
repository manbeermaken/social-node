{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    // This is the magic that enables true ES Modules in Node
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ESNext",

    // Essential for Node/Express
    "types": ["node"],
    
    // Strictness and Code Quality
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    
    // Output settings
    "sourceMap": true,
    
    // Modern TS optimizations
    "isolatedModules": true,
    "verbatimModuleSyntax": true,

    // set root folder
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
