generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  username  String   @unique
  password  String
  role      Role     @default(USER)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([username])
  @@map("users")
}

enum Role {
  USER
  ADMIN
}
